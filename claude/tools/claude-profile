#!/usr/bin/env bash
# claude-profile — switch between multiple Claude accounts
#
# Usage:
#   claude-profile add <name>         # Save current credentials as a named profile
#   claude-profile use <name>         # Switch to a named profile
#   claude-profile list               # List saved profiles
#   claude-profile current            # Show active profile
#   claude-profile remove <name>      # Delete a saved profile
#   claude-profile auto               # Auto-select profile based on .claude-profile in cwd
#   claude-profile pool <n1> <n2> ... # Create a rotation pool for a project
#   claude-profile next               # Rotate to the next profile in the pool

set -euo pipefail

PROFILES_DIR="${HOME}/.claude/profiles"
CREDS_FILE="${HOME}/.claude/.credentials.json"
ACTIVE_FILE="${PROFILES_DIR}/.active"
SESSIONS_DIR="${PROFILES_DIR}/sessions"

mkdir -p "$PROFILES_DIR" "$SESSIONS_DIR"

red() { printf '\033[31m%s\033[0m\n' "$1"; }
green() { printf '\033[32m%s\033[0m\n' "$1"; }
yellow() { printf '\033[33m%s\033[0m\n' "$1"; }
dim() { printf '\033[2m%s\033[0m\n' "$1"; }

get_sub() {
  python3 -c "import json; print(json.load(open('$1')).get('claudeAiOauth',{}).get('subscriptionType','unknown'))" 2>/dev/null || echo "?"
}

# --- Session tracking ---
# Each shell registers PID -> profile so we can detect conflicts

_cleanup_stale_sessions() {
  for f in "${SESSIONS_DIR}"/*.session; do
    [[ -f "$f" ]] || continue
    local pid
    pid=$(basename "$f" .session)
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$f"
    fi
  done
}

_register_session() {
  local name="$1"
  echo "$name" > "${SESSIONS_DIR}/$$.session"
}

_unregister_session() {
  rm -f "${SESSIONS_DIR}/$$.session"
}

_active_sessions() {
  # Print "pid:profile" for each live session (excluding current shell)
  _cleanup_stale_sessions
  for f in "${SESSIONS_DIR}"/*.session; do
    [[ -f "$f" ]] || continue
    local pid
    pid=$(basename "$f" .session)
    [[ "$pid" == "$$" ]] && continue
    local prof
    prof=$(cat "$f")
    echo "${pid}:${prof}"
  done
}

_conflicting_sessions() {
  # Return sessions using a DIFFERENT profile than $1
  local target="$1"
  _active_sessions | while IFS=: read -r pid prof; do
    [[ "$prof" != "$target" ]] && echo "${pid}:${prof}"
  done
}

_write_creds() {
  local name="$1"
  local profile="${PROFILES_DIR}/${name}.json"
  cp "$profile" "$CREDS_FILE"
  # snapshot creds mtime so we can detect re-auth
  stat -c %Y "$CREDS_FILE" 2>/dev/null > "${PROFILES_DIR}/.creds_mtime" || \
    stat -f %m "$CREDS_FILE" 2>/dev/null > "${PROFILES_DIR}/.creds_mtime" || true
}

# --- Commands ---

cmd_add() {
  local name="${1:?Usage: claude-profile add <name>}"
  if [[ ! -f "$CREDS_FILE" ]]; then
    red "No credentials found at $CREDS_FILE — log in first with 'claude'"
    exit 1
  fi
  cp "$CREDS_FILE" "${PROFILES_DIR}/${name}.json"
  echo "$name" > "$ACTIVE_FILE"
  _register_session "$name"
  green "Saved current credentials as profile '$name'"
  dim "  subscription: $(get_sub "${PROFILES_DIR}/${name}.json")"
}

cmd_use() {
  local force=0
  if [[ "${1:-}" == "--force" ]]; then
    force=1
    shift
  fi
  local name="${1:?Usage: claude-profile use <name>}"
  local profile="${PROFILES_DIR}/${name}.json"
  if [[ ! -f "$profile" ]]; then
    red "Profile '$name' not found. Available profiles:"
    cmd_list
    exit 1
  fi

  # Check for conflicting sessions
  local conflicts
  conflicts=$(_conflicting_sessions "$name")
  if [[ -n "$conflicts" && "$force" -eq 0 ]]; then
    yellow "Other shells are using different profiles:"
    echo "$conflicts" | while IFS=: read -r pid prof; do
      dim "  PID $pid → $prof"
    done
    yellow "Writing creds file would affect them."
    yellow "Use 'claude-profile use --force $name' to override,"
    yellow "or just rely on the shell hook (ANTHROPIC_OAUTH_TOKEN is set per-shell)."
    # Still register this shell and update active marker, but skip creds file
    echo "$name" > "$ACTIVE_FILE"
    _register_session "$name"
    green "Shell registered with profile '$name' (creds file unchanged)"
    dim "  subscription: $(get_sub "$profile")"
    return 0
  fi

  _write_creds "$name"
  echo "$name" > "$ACTIVE_FILE"
  _register_session "$name"
  green "Switched to profile '$name'"
  dim "  subscription: $(get_sub "$profile")"
}

cmd_sync() {
  if [[ ! -f "$ACTIVE_FILE" ]]; then
    red "No active profile set"
    exit 1
  fi
  local name
  name=$(cat "$ACTIVE_FILE")
  local profile="${PROFILES_DIR}/${name}.json"
  if [[ ! -f "$CREDS_FILE" ]]; then
    red "No credentials found"
    exit 1
  fi
  cp "$CREDS_FILE" "$profile"
  stat -c %Y "$CREDS_FILE" 2>/dev/null > "${PROFILES_DIR}/.creds_mtime" || \
    stat -f %m "$CREDS_FILE" 2>/dev/null > "${PROFILES_DIR}/.creds_mtime" || true
  green "Synced credentials back to profile '$name'"
  dim "  subscription: $(get_sub "$profile")"
}

cmd_auto_sync() {
  [[ -f "$ACTIVE_FILE" ]] || return 0
  [[ -f "$CREDS_FILE" ]] || return 0
  local saved_mtime=""
  [[ -f "${PROFILES_DIR}/.creds_mtime" ]] && saved_mtime=$(cat "${PROFILES_DIR}/.creds_mtime")
  local current_mtime
  current_mtime=$(stat -c %Y "$CREDS_FILE" 2>/dev/null || stat -f %m "$CREDS_FILE" 2>/dev/null || echo "")
  [[ -z "$current_mtime" ]] && return 0
  [[ "$current_mtime" == "$saved_mtime" ]] && return 0
  # Credentials file changed — sync back to active profile
  local name
  name=$(cat "$ACTIVE_FILE")
  local profile="${PROFILES_DIR}/${name}.json"
  cp "$CREDS_FILE" "$profile"
  echo "$current_mtime" > "${PROFILES_DIR}/.creds_mtime"
  dim "Auto-synced refreshed credentials to profile '$name'"
}

cmd_list() {
  local active=""
  [[ -f "$ACTIVE_FILE" ]] && active=$(cat "$ACTIVE_FILE")

  local pool_file=""
  local pool_profiles=()
  pool_file=$(find_pool_file)
  if [[ -n "$pool_file" ]]; then
    while IFS= read -r _line; do pool_profiles+=("$_line"); done < "$pool_file"
  fi

  _cleanup_stale_sessions

  local found=0
  for f in "${PROFILES_DIR}"/*.json; do
    [[ -f "$f" ]] || continue
    found=1
    local name
    name=$(basename "$f" .json)
    local sub
    sub=$(get_sub "$f")
    local marker=" "
    [[ "$name" == "$active" ]] && marker="*"
    local pool_marker=""
    for p in "${pool_profiles[@]+"${pool_profiles[@]}"}"; do
      [[ "$p" == "$name" ]] && pool_marker=" [pool]"
    done
    # collect PIDs for this profile from session files
    local session_pids=""
    for sf in "${SESSIONS_DIR}"/*.session; do
      [[ -f "$sf" ]] || continue
      local sp
      sp=$(cat "$sf")
      if [[ "$sp" == "$name" ]]; then
        local spid
        spid=$(basename "$sf" .session)
        if [[ -n "$session_pids" ]]; then
          session_pids="${session_pids}, $spid"
        else
          session_pids="$spid"
        fi
      fi
    done
    local session_marker=""
    [[ -n "$session_pids" ]] && session_marker=" [active: PID $session_pids]"
    printf " %s %-20s %s%s%s\n" "$marker" "$name" "($sub)" "$pool_marker" "$session_marker"
  done

  if [[ $found -eq 0 ]]; then
    dim "  No profiles saved. Run: claude-profile add <name>"
  fi
}

cmd_current() {
  if [[ -f "$ACTIVE_FILE" ]]; then
    cat "$ACTIVE_FILE"
  else
    echo "(none)"
  fi
}

cmd_remove() {
  local name="${1:?Usage: claude-profile remove <name>}"
  local profile="${PROFILES_DIR}/${name}.json"
  if [[ ! -f "$profile" ]]; then
    red "Profile '$name' not found"
    exit 1
  fi
  rm "$profile"
  green "Removed profile '$name'"
  [[ -f "$ACTIVE_FILE" ]] && [[ "$(cat "$ACTIVE_FILE")" == "$name" ]] && rm "$ACTIVE_FILE"
}

find_pool_file() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.claude-pool" ]]; then
      echo "$dir/.claude-pool"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  echo ""
}

cmd_pool() {
  if [[ $# -lt 2 ]]; then
    red "Usage: claude-profile pool <profile1> <profile2> [profile3] ..."
    exit 1
  fi
  for name in "$@"; do
    if [[ ! -f "${PROFILES_DIR}/${name}.json" ]]; then
      red "Profile '$name' not found"
      exit 1
    fi
  done
  printf '%s\n' "$@" > .claude-pool
  green "Created pool with ${#} profiles in $(pwd)/.claude-pool"
  for name in "$@"; do
    dim "  - $name ($(get_sub "${PROFILES_DIR}/${name}.json"))"
  done
  cmd_use "$1"
}

cmd_next() {
  local pool_file
  pool_file=$(find_pool_file)
  if [[ -z "$pool_file" ]]; then
    red "No .claude-pool found. Create one with: claude-profile pool <p1> <p2> ..."
    exit 1
  fi
  local profiles=()
  while IFS= read -r _line; do profiles+=("$_line"); done < "$pool_file"
  if [[ ${#profiles[@]} -eq 0 ]]; then
    red "Pool file is empty"
    exit 1
  fi
  local current=""
  [[ -f "$ACTIVE_FILE" ]] && current=$(cat "$ACTIVE_FILE")
  local next_idx=0
  for i in "${!profiles[@]}"; do
    if [[ "${profiles[$i]}" == "$current" ]]; then
      next_idx=$(( (i + 1) % ${#profiles[@]} ))
      break
    fi
  done
  local next_name="${profiles[$next_idx]}"
  yellow "Rotating: $current → $next_name"
  cmd_use "$next_name"
}

cmd_pool_status() {
  local pool_file
  pool_file=$(find_pool_file)
  if [[ -z "$pool_file" ]]; then
    dim "No pool configured for this directory"
    return
  fi
  local profiles=()
  while IFS= read -r _line; do profiles+=("$_line"); done < "$pool_file"
  local current=""
  [[ -f "$ACTIVE_FILE" ]] && current=$(cat "$ACTIVE_FILE")
  echo "Pool: $pool_file"
  for i in "${!profiles[@]}"; do
    local name="${profiles[$i]}"
    local marker="  "
    [[ "$name" == "$current" ]] && marker="→ "
    printf " %s%-20s (%s)\n" "$marker" "$name" "$(get_sub "${PROFILES_DIR}/${name}.json" 2>/dev/null)"
  done
}

cmd_auto() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.claude-profile" ]]; then
      local name
      name=$(cat "$dir/.claude-profile" | tr -d '[:space:]')
      if [[ -n "$name" ]]; then
        local current=""
        [[ -f "$ACTIVE_FILE" ]] && current=$(cat "$ACTIVE_FILE")
        if [[ "$name" != "$current" ]]; then
          # In auto mode, silently skip creds write if conflicts exist
          local conflicts
          conflicts=$(_conflicting_sessions "$name")
          if [[ -n "$conflicts" ]]; then
            # Don't clobber — just register this shell and set env var
            echo "$name" > "$ACTIVE_FILE"
            _register_session "$name"
            return 0
          fi
          cmd_use "$name"
        fi
        return 0
      fi
    fi
    if [[ -f "$dir/.claude-pool" ]]; then
      local profiles=()
      while IFS= read -r _line; do profiles+=("$_line"); done < "$dir/.claude-pool"
      local current=""
      [[ -f "$ACTIVE_FILE" ]] && current=$(cat "$ACTIVE_FILE")
      for p in "${profiles[@]}"; do
        [[ "$p" == "$current" ]] && return 0
      done
      if [[ ${#profiles[@]} -gt 0 ]]; then
        local conflicts
        conflicts=$(_conflicting_sessions "${profiles[0]}")
        if [[ -n "$conflicts" ]]; then
          echo "${profiles[0]}" > "$ACTIVE_FILE"
          _register_session "${profiles[0]}"
          return 0
        fi
        cmd_use "${profiles[0]}"
      fi
      return 0
    fi
    dir=$(dirname "$dir")
  done
}

cmd_set() {
  local name="${1:?Usage: claude-profile set <name>}"
  if [[ ! -f "${PROFILES_DIR}/${name}.json" ]]; then
    red "Profile '$name' not found. Available profiles:"
    cmd_list
    exit 1
  fi
  echo "$name" > .claude-profile
  green "Set project profile to '$name' in $(pwd)/.claude-profile"
  cmd_use "$name"
}

cmd_token() {
  local profile="${1:-}"
  local creds
  if [[ -n "$profile" ]]; then
    creds="${PROFILES_DIR}/${profile}.json"
    if [[ ! -f "$creds" ]]; then
      red "Profile '$profile' not found" >&2
      exit 1
    fi
  else
    # Read from this shell's registered profile first, fall back to global creds
    local shell_profile="${SESSIONS_DIR}/$$.session"
    if [[ -f "$shell_profile" ]]; then
      local name
      name=$(cat "$shell_profile")
      creds="${PROFILES_DIR}/${name}.json"
    else
      creds="$CREDS_FILE"
    fi
  fi
  if [[ ! -f "$creds" ]]; then
    red "No credentials found" >&2
    exit 1
  fi
  python3 -c "import json; print(json.load(open('$creds'))['claudeAiOauth']['accessToken'])"
}

cmd_env() {
  local token
  token=$(cmd_token "${1:-}")
  echo "export ANTHROPIC_OAUTH_TOKEN=\"$token\""
}

cmd_wrap() {
  local token
  token=$(cmd_token "")
  ANTHROPIC_OAUTH_TOKEN="$token" exec "$@"
}

cmd_shell_hook() {
  cat <<'HOOK'
# Full auto-detect: runs on cd to pick up .claude-profile/.claude-pool
claude_profile_auto() {
  if command -v claude-profile &>/dev/null; then
    claude-profile auto 2>/dev/null
    local _token
    _token=$(claude-profile token 2>/dev/null) && export ANTHROPIC_OAUTH_TOKEN="$_token"
  fi
}
# Lightweight token refresh: runs before every prompt so pool rotations
# in other shells are picked up immediately (no python3 fork — pure bash)
claude_profile_refresh_token() {
  local _profiles_dir="${HOME}/.claude/profiles"
  local _sessions_dir="${_profiles_dir}/sessions"
  local _session_file="${_sessions_dir}/$$.session"
  local _active_file="${_profiles_dir}/.active"
  local _name=""
  if [[ -f "$_session_file" ]]; then
    _name=$(cat "$_session_file")
  elif [[ -f "$_active_file" ]]; then
    _name=$(cat "$_active_file")
  fi
  if [[ -n "$_name" && -f "${_profiles_dir}/${_name}.json" ]]; then
    # Extract token without forking python3 — use grep+sed on the JSON
    local _tok
    _tok=$(grep -o '"accessToken":"[^"]*"' "${_profiles_dir}/${_name}.json" 2>/dev/null | head -1 | sed 's/"accessToken":"//;s/"$//')
    [[ -n "$_tok" ]] && export ANTHROPIC_OAUTH_TOKEN="$_tok"
  fi
}
if [[ -n "$ZSH_VERSION" ]]; then
  autoload -U add-zsh-hook
  add-zsh-hook -d chpwd claude_profile_auto 2>/dev/null || true
  add-zsh-hook chpwd claude_profile_auto
  add-zsh-hook -d precmd claude_profile_refresh_token 2>/dev/null || true
  add-zsh-hook precmd claude_profile_refresh_token
else
  case ";${PROMPT_COMMAND:-};" in
    *";claude_profile_refresh_token;"*) ;;
    *) PROMPT_COMMAND="claude_profile_refresh_token${PROMPT_COMMAND:+;${PROMPT_COMMAND}}" ;;
  esac
fi
claude_profile_auto
HOOK
}

cmd_sessions() {
  _cleanup_stale_sessions
  local found=0
  for f in "${SESSIONS_DIR}"/*.session; do
    [[ -f "$f" ]] || continue
    found=1
    local pid prof
    pid=$(basename "$f" .session)
    prof=$(cat "$f")
    local marker=" "
    [[ "$pid" == "$$" ]] && marker="*"
    printf " %s PID %-8s → %s\n" "$marker" "$pid" "$prof"
  done
  if [[ $found -eq 0 ]]; then
    dim "  No active sessions"
  fi
}

# Auto-sync before any command that might switch profiles
case "${1:-help}" in
  use|switch|next|rotate|auto|list|ls|pool-status|ps|token|env|wrap|sessions)
    cmd_auto_sync ;;
esac

case "${1:-help}" in
  add)              cmd_add "${2:-}" ;;
  use|switch)       shift; cmd_use "$@" ;;
  set)              cmd_set "${2:-}" ;;
  list|ls)          cmd_list ;;
  current)          cmd_current ;;
  remove|rm)        cmd_remove "${2:-}" ;;
  pool)             shift; cmd_pool "$@" ;;
  next|rotate)      cmd_next ;;
  pool-status|ps)   cmd_pool_status ;;
  auto)             cmd_auto ;;
  sync)             cmd_sync ;;
  token)            cmd_token "${2:-}" ;;
  env)              cmd_env "${2:-}" ;;
  wrap)             shift; cmd_wrap "$@" ;;
  shell-hook)       cmd_shell_hook ;;
  sessions)         cmd_sessions ;;
  *)
    echo "claude-profile — manage multiple Claude accounts"
    echo ""
    echo "  add <name>            Save current credentials"
    echo "  use <name>            Switch to a profile (this session)"
    echo "  use --force <name>    Switch even if other sessions conflict"
    echo "  set <name>            Set profile for this project directory"
    echo "  list                  List all profiles"
    echo "  current               Show active profile"
    echo "  remove <name>         Delete a profile"
    echo ""
    echo "  pool <n1> <n2> ...    Create rotation pool for this directory"
    echo "  next                  Rotate to next in pool"
    echo "  pool-status           Show pool + active"
    echo ""
    echo "  sessions              Show active shell sessions + their profiles"
    echo "  sync                  Update active profile after re-authentication"
    echo ""
    echo "  token [profile]       Print OAuth access token (active or named profile)"
    echo "  env [profile]         Print export for ANTHROPIC_OAUTH_TOKEN"
    echo "  wrap <cmd> [args...]  Run a command with ANTHROPIC_OAUTH_TOKEN set"
    echo ""
    echo "  auto                  Auto-select from .claude-profile/.claude-pool"
    echo "  shell-hook            Print shell hook for cd auto-switching"
    echo ""
    echo "Pi integration:"
    echo "  claude-profile wrap pi --provider anthropic --model claude-sonnet-4-6"
    echo "  eval \"\$(claude-profile env)\" && pi --provider anthropic"
    ;;
esac
