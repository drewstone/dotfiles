#!/usr/bin/env bash
# claude-profile — switch between multiple Claude accounts
#
# Usage:
#   claude-profile add <name>         # Save current credentials as a named profile
#   claude-profile use <name>         # Switch to a named profile
#   claude-profile list               # List saved profiles
#   claude-profile current            # Show active profile
#   claude-profile remove <name>      # Delete a saved profile
#   claude-profile auto               # Auto-select profile based on .claude-profile in cwd
#
# Per-directory auto-switching:
#   echo "work" > ~/code/phony/.claude-profile
#   echo "personal" > ~/code/sideproject/.claude-profile
#   # Add to .bashrc/.zshrc: eval "$(claude-profile shell-hook)"

set -euo pipefail

PROFILES_DIR="${HOME}/.claude/profiles"
CREDS_FILE="${HOME}/.claude/.credentials.json"
ACTIVE_FILE="${PROFILES_DIR}/.active"

mkdir -p "$PROFILES_DIR"

red() { printf '\033[31m%s\033[0m\n' "$1"; }
green() { printf '\033[32m%s\033[0m\n' "$1"; }
dim() { printf '\033[2m%s\033[0m\n' "$1"; }

cmd_add() {
  local name="${1:?Usage: claude-profile add <name>}"
  if [[ ! -f "$CREDS_FILE" ]]; then
    red "No credentials found at $CREDS_FILE — log in first with 'claude'"
    exit 1
  fi
  cp "$CREDS_FILE" "${PROFILES_DIR}/${name}.json"
  echo "$name" > "$ACTIVE_FILE"
  green "Saved current credentials as profile '$name'"

  # Show subscription type
  local sub
  sub=$(python3 -c "import json; print(json.load(open('${PROFILES_DIR}/${name}.json')).get('claudeAiOauth',{}).get('subscriptionType','unknown'))" 2>/dev/null || echo "unknown")
  dim "  subscription: $sub"
}

cmd_use() {
  local name="${1:?Usage: claude-profile use <name>}"
  local profile="${PROFILES_DIR}/${name}.json"
  if [[ ! -f "$profile" ]]; then
    red "Profile '$name' not found. Available profiles:"
    cmd_list
    exit 1
  fi
  cp "$profile" "$CREDS_FILE"
  echo "$name" > "$ACTIVE_FILE"
  green "Switched to profile '$name'"

  local sub
  sub=$(python3 -c "import json; print(json.load(open('$profile')).get('claudeAiOauth',{}).get('subscriptionType','unknown'))" 2>/dev/null || echo "unknown")
  dim "  subscription: $sub"
}

cmd_list() {
  local active=""
  [[ -f "$ACTIVE_FILE" ]] && active=$(cat "$ACTIVE_FILE")

  local found=0
  for f in "${PROFILES_DIR}"/*.json; do
    [[ -f "$f" ]] || continue
    found=1
    local name
    name=$(basename "$f" .json)
    local sub
    sub=$(python3 -c "import json; print(json.load(open('$f')).get('claudeAiOauth',{}).get('subscriptionType','unknown'))" 2>/dev/null || echo "?")
    local marker=" "
    [[ "$name" == "$active" ]] && marker="*"
    printf " %s %-20s %s\n" "$marker" "$name" "($sub)"
  done

  if [[ $found -eq 0 ]]; then
    dim "  No profiles saved. Run: claude-profile add <name>"
  fi
}

cmd_current() {
  if [[ -f "$ACTIVE_FILE" ]]; then
    cat "$ACTIVE_FILE"
  else
    echo "(none)"
  fi
}

cmd_remove() {
  local name="${1:?Usage: claude-profile remove <name>}"
  local profile="${PROFILES_DIR}/${name}.json"
  if [[ ! -f "$profile" ]]; then
    red "Profile '$name' not found"
    exit 1
  fi
  rm "$profile"
  green "Removed profile '$name'"

  # Clear active if it was this one
  [[ -f "$ACTIVE_FILE" ]] && [[ "$(cat "$ACTIVE_FILE")" == "$name" ]] && rm "$ACTIVE_FILE"
}

cmd_auto() {
  # Walk up from cwd looking for .claude-profile
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.claude-profile" ]]; then
      local name
      name=$(cat "$dir/.claude-profile" | tr -d '[:space:]')
      if [[ -n "$name" ]]; then
        local current=""
        [[ -f "$ACTIVE_FILE" ]] && current=$(cat "$ACTIVE_FILE")
        if [[ "$name" != "$current" ]]; then
          cmd_use "$name"
        fi
        return 0
      fi
    fi
    dir=$(dirname "$dir")
  done
  # No .claude-profile found — leave as-is
}

cmd_shell_hook() {
  cat <<'HOOK'
# Claude profile auto-switching — add to .bashrc/.zshrc
claude_profile_auto() {
  if command -v claude-profile &>/dev/null; then
    claude-profile auto 2>/dev/null
  fi
}
if [[ -n "$ZSH_VERSION" ]]; then
  autoload -U add-zsh-hook
  add-zsh-hook chpwd claude_profile_auto
else
  PROMPT_COMMAND="claude_profile_auto;${PROMPT_COMMAND:-}"
fi
HOOK
}

# --- Dispatch ---
case "${1:-help}" in
  add)          cmd_add "${2:-}" ;;
  use|switch)   cmd_use "${2:-}" ;;
  list|ls)      cmd_list ;;
  current)      cmd_current ;;
  remove|rm)    cmd_remove "${2:-}" ;;
  auto)         cmd_auto ;;
  shell-hook)   cmd_shell_hook ;;
  *)
    echo "claude-profile — manage multiple Claude accounts"
    echo ""
    echo "Commands:"
    echo "  add <name>       Save current credentials as a named profile"
    echo "  use <name>       Switch to a named profile"
    echo "  list             List saved profiles"
    echo "  current          Show active profile name"
    echo "  remove <name>    Delete a saved profile"
    echo "  auto             Auto-select based on .claude-profile in cwd ancestors"
    echo "  shell-hook       Print shell hook for auto-switching on cd"
    echo ""
    echo "Per-directory auto-switching:"
    echo "  echo 'work' > ~/code/phony/.claude-profile"
    echo "  eval \"\$(claude-profile shell-hook)\"  # add to .bashrc/.zshrc"
    ;;
esac
