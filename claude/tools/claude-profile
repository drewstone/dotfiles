#!/usr/bin/env bash
# claude-profile — switch between multiple Claude Code accounts.
#
# Design (v2, 2026-04-19 rewrite):
#
# Each profile is its own complete CLAUDE_CONFIG_DIR. Activation means
# exporting CLAUDE_CONFIG_DIR for the current shell. That's it.
#
# Why this is race-free and bug-free:
#
# - Claude Code honors CLAUDE_CONFIG_DIR (verified against the binary)
#   and reads/writes EVERYTHING — credentials, history, projects, settings
#   — from that single directory.
# - No shared file is ever rewritten. Two concurrent `claude` sessions
#   with different CLAUDE_CONFIG_DIR values never touch each other's state.
# - Logging in with another account is just: run `claude` with a different
#   CLAUDE_CONFIG_DIR pointing at a fresh (or existing) profile dir. No
#   sync, no "active" marker to update, no cross-shell coordination.
# - The shell hook only exports env vars. It never writes files. It can't
#   clobber a running session's credentials because it doesn't touch them.
#
# Layout:
#
#   ~/.claude-profiles/
#     .default                  # name of default profile for new shells (optional)
#     <name>/                   # this dir == CLAUDE_CONFIG_DIR for the profile
#       .credentials.json       # written by `claude` during OAuth login
#       .claude.json            # written by `claude` at runtime
#       projects/  sessions/  backups/   # also owned by `claude`
#
# The legacy ~/.claude/ directory is left intact as the "no profile
# selected" fallback so users who don't opt into profiles see zero change.
#
# Compatible with zsh 5+ and bash 3.2+ (macOS stock bash).

set -euo pipefail

PROFILES_DIR="${CLAUDE_PROFILES_DIR:-$HOME/.claude-profiles}"
DEFAULT_FILE="${PROFILES_DIR}/.default"
LEGACY_CREDS="$HOME/.claude/.credentials.json"

mkdir -p "$PROFILES_DIR"

# --- colors (only when stdout is a TTY) ---
if [[ -t 1 ]]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RED=$'\033[31m'; GREEN=$'\033[32m'
  YELLOW=$'\033[33m'; CYAN=$'\033[36m'; RESET=$'\033[0m'
else
  BOLD=''; DIM=''; RED=''; GREEN=''; YELLOW=''; CYAN=''; RESET=''
fi
_say()  { printf '%s\n' "$*"; }
_dim()  { printf '%s%s%s\n' "$DIM" "$*" "$RESET"; }
_red()  { printf '%s%s%s\n' "$RED" "$*" "$RESET" >&2; }
_grn()  { printf '%s%s%s\n' "$GREEN" "$*" "$RESET"; }
_warn() { printf '%s%s%s\n' "$YELLOW" "$*" "$RESET" >&2; }
_info() { printf '%s%s%s\n' "$CYAN" "$*" "$RESET"; }

# --- helpers ---

_profile_dir() { printf '%s/%s' "$PROFILES_DIR" "$1"; }

_profile_exists() {
  [[ -n "${1:-}" && -d "$(_profile_dir "$1")" ]]
}

_validate_name() {
  # Profile names become directory names — lock them down to alnum + dash
  # + underscore. Rejects '/', '..', whitespace, '.', leading '-'.
  local name="$1"
  if [[ -z "$name" ]]; then
    _red "profile name required"
    exit 2
  fi
  if ! [[ "$name" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}$ ]]; then
    _red "invalid profile name: $(printf '%q' "$name")"
    _red "  must match /^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}\$/"
    exit 2
  fi
}

_creds_in() {
  printf '%s/.credentials.json' "$1"
}

_get_sub() {
  # Best-effort subscription label from a creds file. Pure bash — no python.
  local creds="$1"
  [[ -f "$creds" ]] || { printf 'no-creds'; return; }
  local line sub
  line=$(grep -o '"subscriptionType":"[^"]*"' "$creds" 2>/dev/null | head -1 || true)
  sub=${line#\"subscriptionType\":\"}
  sub=${sub%\"}
  [[ -n "$sub" ]] || sub='unknown'
  printf '%s' "$sub"
}

_get_expires_at() {
  # Epoch ms from creds (Claude stores UNIX ms). Empty string if missing.
  local creds="$1"
  [[ -f "$creds" ]] || return
  grep -o '"expiresAt":[0-9]*' "$creds" 2>/dev/null | head -1 | cut -d: -f2 || true
}

_current_from_env() {
  # Which profile does the CURRENT shell point at? Derived from CLAUDE_CONFIG_DIR.
  local cfg="${CLAUDE_CONFIG_DIR:-}"
  [[ -z "$cfg" ]] && return
  local base
  base=$(basename "$cfg")
  if _profile_exists "$base" && [[ "$(_profile_dir "$base")" == "$cfg" ]]; then
    printf '%s' "$base"
  fi
}

_default_name() {
  [[ -f "$DEFAULT_FILE" ]] || return
  local name
  name=$(head -1 "$DEFAULT_FILE" | tr -d '[:space:]' || true)
  [[ -n "$name" ]] && _profile_exists "$name" && printf '%s' "$name"
}

# --- commands ---

cmd_list() {
  local current default
  current=$(_current_from_env || true)
  default=$(_default_name || true)

  local found=0
  for dir in "$PROFILES_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    found=1
    local name sub marker
    name=$(basename "$dir")
    sub=$(_get_sub "$(_creds_in "$dir")")
    marker='  '
    [[ "$name" == "$current" ]] && marker="${GREEN}→ ${RESET}"
    local def_tag=''
    [[ "$name" == "$default" ]] && def_tag=" ${DIM}[default]${RESET}"
    local logged_in=''
    [[ -f "$(_creds_in "$dir")" ]] || logged_in=" ${YELLOW}[not logged in]${RESET}"
    printf ' %s%s%-24s%s  (%s)%s%s\n' "$marker" "$BOLD" "$name" "$RESET" "$sub" "$def_tag" "$logged_in"
  done

  if [[ $found -eq 0 ]]; then
    _dim "No profiles saved yet. Next steps:"
    _dim "  claude-profile add <name>       — create a fresh profile (runs login)"
    _dim "  claude-profile import <name>    — snapshot ~/.claude/ as a profile"
    return
  fi

  _say
  if [[ -n "$current" ]]; then
    _dim "This shell: $current   (via CLAUDE_CONFIG_DIR)"
  elif [[ -n "$default" ]]; then
    _dim "This shell: $default   (from default — start a new shell to apply)"
  else
    _dim "This shell: legacy ~/.claude/   (no profile active)"
  fi
}

cmd_current() {
  local current default
  current=$(_current_from_env || true)
  default=$(_default_name || true)
  if [[ -n "$current" ]]; then
    printf '%s\n' "$current"
  elif [[ -n "$default" ]]; then
    _dim "(default: $default — not active in this shell)"
    printf '%s\n' "$default"
  else
    printf '%s\n' '(none)'
  fi
}

cmd_add() {
  local name="${1:?Usage: claude-profile add <name>}"
  _validate_name "$name"
  local dir; dir=$(_profile_dir "$name")
  if _profile_exists "$name"; then
    _warn "Profile '$name' already exists at $dir"
    _warn "  To re-authenticate: claude-profile login $name"
    _warn "  To delete and recreate: claude-profile remove $name"
    exit 1
  fi
  mkdir -p "$dir"
  _grn "Created profile '$name'"
  _info "Starting login flow in isolated dir..."
  _dim "  CLAUDE_CONFIG_DIR=$dir"
  _dim "  When /login completes, Ctrl+D or /exit to return."
  _say
  CLAUDE_CONFIG_DIR="$dir" claude || true
  if [[ -f "$(_creds_in "$dir")" ]]; then
    _grn "Profile '$name' is logged in (subscription: $(_get_sub "$(_creds_in "$dir")"))."
    if [[ ! -f "$DEFAULT_FILE" ]] && [[ $(find "$PROFILES_DIR" -maxdepth 1 -type d ! -path "$PROFILES_DIR" | wc -l) -eq 1 ]]; then
      printf '%s' "$name" > "$DEFAULT_FILE"
      _dim "  Marked '$name' as the default for new shells."
    fi
    _say
    _info "To activate in this shell:"
    _dim "    claude-profile use $name"
  else
    _warn "No credentials were written — did the login flow complete?"
    _warn "  Re-run: claude-profile login $name"
  fi
}

cmd_login() {
  local name="${1:?Usage: claude-profile login <name>}"
  _validate_name "$name"
  if ! _profile_exists "$name"; then
    _red "Profile '$name' not found. Create it with: claude-profile add $name"
    exit 1
  fi
  local dir; dir=$(_profile_dir "$name")
  _info "Re-running login for '$name'..."
  _dim "  CLAUDE_CONFIG_DIR=$dir"
  CLAUDE_CONFIG_DIR="$dir" claude || true
  if [[ -f "$(_creds_in "$dir")" ]]; then
    _grn "Profile '$name' refreshed (subscription: $(_get_sub "$(_creds_in "$dir")"))."
  else
    _warn "No credentials written — login flow may not have completed."
  fi
}

cmd_import() {
  # Snapshot legacy ~/.claude/.credentials.json into a named profile. Useful
  # when switching to the profile model from a single pre-existing account.
  local name="${1:?Usage: claude-profile import <name>}"
  _validate_name "$name"
  if [[ ! -f "$LEGACY_CREDS" ]]; then
    _red "No credentials at $LEGACY_CREDS — nothing to import."
    _red "  Log in first: claude /login"
    exit 1
  fi
  if _profile_exists "$name"; then
    _red "Profile '$name' already exists. Remove it first or pick another name."
    exit 1
  fi
  local dir; dir=$(_profile_dir "$name")
  mkdir -p "$dir"
  install -m 0600 "$LEGACY_CREDS" "$(_creds_in "$dir")"
  _grn "Imported current credentials as profile '$name' (subscription: $(_get_sub "$(_creds_in "$dir")"))."
  if [[ ! -f "$DEFAULT_FILE" ]]; then
    printf '%s' "$name" > "$DEFAULT_FILE"
    _dim "  Marked '$name' as the default for new shells."
  fi
  _info "To activate in this shell:   claude-profile use $name"
}

cmd_use() {
  # The binary can't mutate the caller's env. The `use` command only works
  # via the shell function installed by `shell-hook` — it evals the export.
  # When run directly, this command refuses and tells the user how to fix.
  local name="${1:?Usage: claude-profile use <name>}"
  _validate_name "$name"
  if ! _profile_exists "$name"; then
    _red "Profile '$name' not found. Available:"
    cmd_list >&2
    exit 1
  fi
  local dir; dir=$(_profile_dir "$name")
  if [[ ! -f "$(_creds_in "$dir")" ]]; then
    _warn "Profile '$name' has no credentials yet. Run: claude-profile login $name"
  fi
  if [[ "${_CLAUDE_PROFILE_VIA_FUNCTION:-}" == "1" ]]; then
    printf 'export CLAUDE_CONFIG_DIR=%q\n' "$dir"
    printf 'printf %%s\\\\n %q > %q\n' "$name" "$DEFAULT_FILE"
  else
    _warn "claude-profile is a shell function when installed correctly."
    _warn "  Add to ~/.bashrc or ~/.zshrc:"
    _warn "      eval \"\$(claude-profile shell-hook)\""
    _warn "  Reload the shell, then re-run: claude-profile use $name"
    _warn ""
    _warn "  One-off without the hook:"
    _warn "      export CLAUDE_CONFIG_DIR=$dir"
    exit 1
  fi
}

cmd_default() {
  if [[ "${1:-}" == "--unset" ]]; then
    rm -f "$DEFAULT_FILE"
    _grn "Default profile unset. New shells will use ~/.claude/."
    return
  fi
  local name="${1:?Usage: claude-profile default <name> | --unset}"
  _validate_name "$name"
  if ! _profile_exists "$name"; then
    _red "Profile '$name' not found."
    exit 1
  fi
  printf '%s' "$name" > "$DEFAULT_FILE"
  _grn "Default profile for new shells set to '$name'."
  if [[ "$(_current_from_env || true)" != "$name" ]]; then
    _dim "  This shell is unchanged — run 'claude-profile use $name' to switch now."
  fi
}

cmd_remove() {
  local name="${1:?Usage: claude-profile remove <name>}"
  _validate_name "$name"
  if ! _profile_exists "$name"; then
    _red "Profile '$name' not found."
    exit 1
  fi
  local dir; dir=$(_profile_dir "$name")
  local force=0
  [[ "${2:-}" == "--force" ]] && force=1
  if [[ $force -eq 0 ]]; then
    if [[ -t 0 ]]; then
      printf '%sDelete %s?%s [y/N] ' "$YELLOW" "$dir" "$RESET"
      local reply; read -r reply
      [[ "$reply" == "y" || "$reply" == "Y" ]] || { _dim "aborted."; exit 0; }
    else
      _red "Refusing to delete '$name' without --force (non-interactive shell)."
      exit 1
    fi
  fi
  # Read the default file DIRECTLY (not via _default_name, which gates on
  # the dir still existing — we're about to delete that dir).
  local raw_default=''
  [[ -f "$DEFAULT_FILE" ]] && raw_default=$(head -1 "$DEFAULT_FILE" | tr -d '[:space:]' 2>/dev/null || true)
  rm -rf "$dir"
  if [[ "$raw_default" == "$name" ]]; then
    rm -f "$DEFAULT_FILE"
    _dim "  Also cleared default (new shells will use ~/.claude/ again)."
  fi
  _grn "Removed profile '$name'."
  if [[ "${CLAUDE_CONFIG_DIR:-}" == "$dir" ]]; then
    _warn "  This shell's CLAUDE_CONFIG_DIR still points at the deleted dir."
    _warn "  Fix: claude-profile use <other-name>   OR   unset CLAUDE_CONFIG_DIR"
  fi
}

cmd_doctor() {
  local now_ms
  now_ms=$(date +%s%3N 2>/dev/null || echo "")
  if [[ -z "$now_ms" || "$now_ms" == *N* ]]; then
    # macOS date has no %N; fall back to seconds*1000.
    now_ms=$(( $(date +%s) * 1000 ))
  fi
  _info "${BOLD}Profiles dir:${RESET} $PROFILES_DIR"
  _say
  local count=0 missing=0 expired=0
  for dir in "$PROFILES_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    count=$((count + 1))
    local name creds exp sub
    name=$(basename "$dir")
    creds=$(_creds_in "$dir")
    if [[ ! -f "$creds" ]]; then
      printf '  %s✗%s %s — no credentials file\n' "$RED" "$RESET" "$name"
      missing=$((missing + 1))
      continue
    fi
    if ! head -c 1 "$creds" | grep -q '{'; then
      printf '  %s✗%s %s — credentials file is not JSON\n' "$RED" "$RESET" "$name"
      continue
    fi
    exp=$(_get_expires_at "$creds")
    sub=$(_get_sub "$creds")
    local stamp=''
    if [[ -n "$exp" && "$exp" =~ ^[0-9]+$ ]]; then
      if [[ "$exp" -lt "$now_ms" ]]; then
        stamp=" ${RED}expired${RESET}"
        expired=$((expired + 1))
      else
        local secs=$(( (exp - now_ms) / 1000 ))
        local human
        if (( secs < 3600 )); then
          human="$((secs / 60))m"
        elif (( secs < 86400 )); then
          human="$((secs / 3600))h"
        else
          human="$((secs / 86400))d"
        fi
        stamp=" ${DIM}(expires in $human)${RESET}"
      fi
    fi
    printf '  %s✓%s %s — %s%s\n' "$GREEN" "$RESET" "$name" "$sub" "$stamp"
  done
  if [[ $count -eq 0 ]]; then
    _dim "No profiles yet."
    return
  fi
  _say
  if [[ $missing -gt 0 || $expired -gt 0 ]]; then
    _warn "$missing missing creds file(s), $expired expired token(s)."
    _warn "  Fix: claude-profile login <name>"
  else
    _dim "All $count profile(s) healthy."
  fi
}

cmd_shell_hook() {
  # Emits the bash/zsh snippet that turns `claude-profile` into a shell
  # function so `use` can mutate the current shell's env. Pure env
  # mutation — no file writes on any hot path.
  cat <<'EOF'
# claude-profile shell hook — injected by `eval "$(claude-profile shell-hook)"`
# Principles: pure env var mutation, zero file writes on hot paths.

# `claude-profile use X` must mutate THIS shell's env — impossible from a
# child process. Wrap it in a shell function that evals the printed export.
claude-profile() {
  case "${1:-}" in
    use)
      local _out
      _out=$(_CLAUDE_PROFILE_VIA_FUNCTION=1 command claude-profile "$@") || return $?
      eval "$_out"
      ;;
    *)
      command claude-profile "$@"
      ;;
  esac
}

# Resolve CLAUDE_CONFIG_DIR at shell startup. Priority:
#   1. Already set by the user (environment) → keep it.
#   2. ~/.claude-profiles/.default names a profile → use it.
#   3. Otherwise unset → claude falls back to ~/.claude/.
__claude_profile_init() {
  local _profiles_dir="${CLAUDE_PROFILES_DIR:-$HOME/.claude-profiles}"
  if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
    return 0
  fi
  local _default_file="${_profiles_dir}/.default"
  [[ -f "$_default_file" ]] || return 0
  local _name
  _name=$(head -1 "$_default_file" | tr -d '[:space:]' 2>/dev/null || true)
  if [[ -n "$_name" && -d "${_profiles_dir}/${_name}" ]]; then
    export CLAUDE_CONFIG_DIR="${_profiles_dir}/${_name}"
  fi
}
__claude_profile_init
unset -f __claude_profile_init

EOF
}

cmd_help() {
  cat <<EOF
${BOLD}claude-profile${RESET} — switch between Claude Code accounts

${BOLD}Core commands:${RESET}
  ${CYAN}list${RESET}                   list profiles (marks active + default)
  ${CYAN}current${RESET}                print the current shell's active profile
  ${CYAN}add <name>${RESET}             create a new profile and run login
  ${CYAN}import <name>${RESET}          snapshot ~/.claude/ as a named profile
  ${CYAN}login <name>${RESET}           re-authenticate an existing profile
  ${CYAN}use <name>${RESET}             switch THIS shell to <name> (requires shell hook)
  ${CYAN}default <name>${RESET}         set default profile for new shells
  ${CYAN}default --unset${RESET}        clear default (new shells use ~/.claude/)
  ${CYAN}remove <name>${RESET}          delete a profile

${BOLD}Diagnostics:${RESET}
  ${CYAN}doctor${RESET}                 audit profiles, flag expired/missing tokens

${BOLD}Shell integration:${RESET}
  Add to ~/.bashrc or ~/.zshrc:
      eval "\$(claude-profile shell-hook)"
  Then \`claude-profile use X\` switches THIS shell to profile X.

${BOLD}Mental model:${RESET}
  Each profile is its own complete \$CLAUDE_CONFIG_DIR under
  ${PROFILES_DIR}/<name>/.
  Activating a profile = setting CLAUDE_CONFIG_DIR in your shell.
  Nothing else. No shared files are rewritten, so two terminals on
  two accounts never race.

${BOLD}Typical setup:${RESET}
  # if you already have an account logged in under ~/.claude/:
  claude-profile import personal
  # add a second account:
  claude-profile add work
  # pick a default for new terminals:
  claude-profile default personal
  # switch this terminal:
  claude-profile use work
EOF
}

# --- dispatch ---

cmd="${1:-help}"
[[ $# -gt 0 ]] && shift || true

case "$cmd" in
  list|ls)                 cmd_list ;;
  current)                 cmd_current ;;
  add)                     cmd_add "$@" ;;
  import|import-current)   cmd_import "$@" ;;
  login)                   cmd_login "$@" ;;
  use|switch)              cmd_use "$@" ;;
  default)                 cmd_default "$@" ;;
  remove|rm)               cmd_remove "$@" ;;
  doctor|status)           cmd_doctor ;;
  shell-hook|hook)         cmd_shell_hook ;;
  help|--help|-h|'')       cmd_help ;;
  *)
    _red "Unknown command: $cmd"
    _say
    cmd_help
    exit 1
    ;;
esac
