{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject-directive.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-push-preflight.sh",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/audit-freshness-check.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_PROJECT_DIR\" ] && [ -x \"$CLAUDE_PROJECT_DIR/scripts/archive-session-transcript.sh\" ] && \"$CLAUDE_PROJECT_DIR/scripts/archive-session-transcript.sh\" >/dev/null 2>&1 || true",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_PROJECT_DIR\" ] && [ -x \"$CLAUDE_PROJECT_DIR/scripts/archive-session-transcript.sh\" ] && \"$CLAUDE_PROJECT_DIR/scripts/archive-session-transcript.sh\" >/dev/null 2>&1 || true",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "codex@openai-codex": true,
    "last30days@last30days-skill": true,
    "tangle-blueprint-innovate@tangle-network-skills": true,
    "agent-factory@tangle-skills-internal": true,
    "agent-platform@tangle-skills-internal": true,
    "blueprint-launch@tangle-skills-internal": true,
    "brand-system@tangle-skills-internal": true,
    "cold-email@tangle-skills-internal": true,
    "community-marketing@tangle-skills-internal": true,
    "competitor-alternatives@tangle-skills-internal": true,
    "content-review@tangle-skills-internal": true,
    "content-strategy@tangle-skills-internal": true,
    "customer-research@tangle-skills-internal": true,
    "free-tool-strategy@tangle-skills-internal": true,
    "launch-strategy@tangle-skills-internal": true,
    "lunour-branding-playbook@tangle-skills-internal": true,
    "persona-workshop@tangle-skills-internal": true,
    "pricing-strategy@tangle-skills-internal": true,
    "programmatic-seo@tangle-skills-internal": true,
    "sales-enablement@tangle-skills-internal": true,
    "tangle-positioning@tangle-skills-internal": true,
    "vault-audit@tangle-skills-internal": true,
    "website-craft@tangle-skills-internal": true,
    "content-engine-images@tangle-skills-internal": true,
    "agent-eval-adoption@tangle-network-skills": true,
    "agent-stack-adoption@tangle-network-skills": true,
    "postiz@tangle-skills-internal": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    },
    "tangle-network-skills": {
      "source": {
        "source": "github",
        "repo": "tangle-network/skills"
      }
    },
    "tangle-skills-internal": {
      "source": {
        "source": "github",
        "repo": "tangle-network/skills-internal"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "autoCompactEnabled": true,
  "switchModelsOnFlag": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
